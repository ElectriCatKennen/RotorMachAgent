        "ω₁,ω₂,ω₃": "各轴角速度(rad/s)"
      }
    },
    "general_conversion": {
      "linear_motion": {"formula": "J_m = mv²/ω₀²", "unit": "kg·m²", "description": "一般移动"},
      "ball_screw": {"formula": "J = mt²/(4π²i²)", "description": "丝杆传动，t为螺距"},
      "gear_rack": {"formula": "J = m(d/i)²/4", "description": "齿轮齿条传动，d为节圆直径"}
    },
    "equivalent_mass": {
      "formula": "m_n = Jω²/v²",
      "description": "转动物体换算为移动速度为v时的当量质量"
    }
  },
