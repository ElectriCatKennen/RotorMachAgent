    },
    "transmission_conversion": {
      "description": "传动系统转动惯量换算到电动机轴",
      "formula": "J = J₁ + J₂/i₁² + J₃/(i₁i₂)² + mr²/(i₁i₂)²",
      "notation": {
        "J₁,J₂,J₃": "各轴上回转体的转动惯量(kg·m²)",
        "m": "移动物体质量(kg)",
